<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>워홀 크리에이터 N잡 챌린지 2기</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
  :root {
    --orange: #FF6B35;
    --amber: #FFB347;
    --coral: #FF8C69;
    --dark: #1A1210;
    --dark2: #2D1F1A;
    --cream: #FFF8F0;
    --warm-gray: #8B7355;
    --gold: #D4A853;
    --light-orange: #FFF0E6;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Noto Sans KR', sans-serif;
    background: var(--cream);
    color: var(--dark);
    overflow-x: hidden;
    word-break: keep-all;
    overflow-wrap: break-word;
    padding-bottom: 92px;
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    background: var(--dark);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 80px 24px 60px;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(255,107,53,0.25) 0%, transparent 70%),
                radial-gradient(ellipse 50% 40% at 80% 80%, rgba(255,179,71,0.15) 0%, transparent 60%);
  }

  .hero-badge {
    display: inline-block;
    background: var(--orange);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    padding: 6px 18px;
    border-radius: 50px;
    margin-bottom: 28px;
    position: relative;
    animation: fadeDown 0.8s ease both;
  }

  .hero-title {
    font-family: 'Noto Sans KR', sans-serif;
    font-size: clamp(38px, 9vw, 82px);
    font-weight: 900;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -2px;
    position: relative;
    animation: fadeDown 0.9s ease 0.1s both;
  }

  .hero-title span {
    display: block;
    background: linear-gradient(90deg, var(--orange), var(--amber));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: clamp(14px, 2.5vw, 18px);
    color: rgba(255,255,255,0.65);
    margin-top: 20px;
    font-weight: 400;
    line-height: 1.7;
    position: relative;
    animation: fadeDown 1s ease 0.2s both;
  }

  .hero-voices {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 40px auto;
    max-width: 560px;
    position: relative;
    animation: fadeDown 1s ease 0.3s both;
  }

  .voice-bubble {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 16px;
    padding: 14px 20px;
    color: rgba(255,255,255,0.85);
    font-size: 12.5px;
    font-weight: 400;
    line-height: 1.5;
    text-align: left;
    backdrop-filter: blur(10px);
  }

  .voice-bubble strong {
    color: var(--amber);
  }

  .hero-cta {
    position: relative;
    animation: fadeDown 1s ease 0.4s both;
  }

  .btn-primary {
    display: inline-block;
    background: linear-gradient(135deg, var(--orange), var(--amber));
    color: #fff;
    font-size: 18px;
    font-weight: 800;
    padding: 18px 52px;
    border-radius: 60px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 40px rgba(255,107,53,0.45);
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(255,107,53,0.55);
  }

  .hero-scroll {
    margin-top: 40px;
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    letter-spacing: 1.5px;
    animation: bounce 2s infinite;
    position: relative;
  }

  /* ===== SECTIONS ===== */
  section {
    padding: 80px 24px;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    color: var(--orange);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(24px, 4.5vw, 36px);
    font-weight: 900;
    line-height: 1.25;
    letter-spacing: -0.5px;
  }

  .section-title em {
    font-style: normal;
    color: var(--orange);
  }

  /* ===== QUOTE BAND ===== */
  .quote-band {
    background: var(--dark);
    padding: 60px 24px;
    text-align: center;
    overflow: hidden;
  }

  .quote-band p {
    font-size: clamp(18px, 4vw, 30px);
    color: #fff;
    font-weight: 700;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }

  .quote-band p span {
    color: var(--amber);
  }

  /* ===== INTRO (ABOUT HOST) ===== */
  .about-host {
    background: var(--light-orange);
    border-radius: 28px;
    padding: 40px 36px;
    border: 2px solid rgba(255,107,53,0.15);
    margin-top: 40px;
    position: relative;
  }

  .host-name {
    font-size: 22px;
    font-weight: 900;
    margin-bottom: 6px;
  }

  .host-tag {
    font-size: 12px;
    color: var(--orange);
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .host-stats {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin: 18px 0;
  }

  .stat-chip {
    background: #fff;
    border: 1.5px solid var(--amber);
    border-radius: 30px;
    padding: 6px 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--dark);
  }

  .host-story {
    font-size: 13px;
    line-height: 1.9;
    color: var(--dark2);
    border-left: 3px solid var(--orange);
    padding-left: 16px;
    margin-top: 16px;
    font-style: italic;
  }

  /* ===== BENEFITS ===== */
  .benefits-section {
    background: var(--dark);
    color: #fff;
  }

  .benefits-section .section-title {
    color: #fff;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 36px;
  }

  .benefit-card {
    background: #fff;
    border: 1.5px solid #EAE0D8;
    border-radius: 20px;
    padding: 24px 22px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .benefit-card:hover {
    border-color: var(--orange);
    box-shadow: 0 4px 20px rgba(255,107,53,0.12);
  }

  .benefit-icon {
    font-size: 28px;
    margin-bottom: 10px;
  }

  .benefit-card h4 {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
    color: var(--orange);
    text-transform: uppercase;
  }

  .benefit-card p {
    font-size: 18px;
    font-weight: 800;
    color: #111;
    line-height: 1.5;
  }

  /* ===== WHO IS IT FOR ===== */
  .fit-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 36px;
  }

  .fit-card {
    border-radius: 20px;
    padding: 28px 24px;
  }

  .fit-card.yes {
    background: var(--light-orange);
    border: 2px solid var(--orange);
  }

  .fit-card.no {
    background: #F5F0EC;
    border: 2px solid #D0C4BC;
  }

  .fit-card h3 {
    font-size: 17px;
    font-weight: 900;
    margin-bottom: 14px;
  }

  .fit-card.yes h3 { color: var(--orange); }
  .fit-card.no h3 { color: var(--warm-gray); }

  .fit-card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .fit-card ul li {
    font-size: 13px;
    line-height: 1.5;
    padding-left: 20px;
    position: relative;
    color: var(--dark2);
  }

  .fit-card.yes ul li::before { content: '✓'; position: absolute; left: 0; color: var(--orange); font-weight: 700; }
  .fit-card.no ul li::before { content: '✗'; position: absolute; left: 0; color: var(--warm-gray); font-weight: 700; }

  /* ===== CURRICULUM ===== */
  .curriculum-section {
    background: var(--dark);
    color: #fff;
  }

  .curriculum-section .section-title { color: #fff; }

  .week-list {
    margin-top: 36px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .week-item {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 18px;
    padding: 20px 24px;
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    align-items: start;
    transition: border-color 0.2s;
  }

  .week-item:hover { border-color: var(--orange); }

  .week-label {
    font-size: 12px;
    font-weight: 800;
    color: var(--orange);
    letter-spacing: 0.5px;
    padding-top: 2px;
  }

  .week-content h4 {
    font-size: 15px;
    font-weight: 700;
    color: var(--amber);
    margin-bottom: 4px;
  }

  .week-content p {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    line-height: 1.65;
  }

  /* ===== SCHEDULE ===== */
  .schedule-box {
    background: var(--light-orange);
    border-radius: 24px;
    padding: 32px 28px;
    border: 2px solid var(--orange);
    margin-top: 36px;
  }

  .schedule-items {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 18px;
  }

  .schedule-row {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 15px;
  }

  .schedule-icon {
    width: 40px;
    height: 40px;
    background: var(--orange);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .schedule-row strong { font-weight: 800; }

  /* ===== PRICING ===== */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 36px;
  }

  .price-card {
    border-radius: 24px;
    padding: 32px 26px;
    position: relative;
    overflow: hidden;
  }

  .price-card.basic {
    background: #fff;
    border: 2px solid #E8DDD5;
  }

  .price-card.premium {
    background: var(--dark);
    border: 2px solid var(--orange);
    color: #fff;
  }

  .price-card .recommend-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background: var(--orange);
    color: #fff;
    font-size: 10px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }

  .price-card h3 {
    font-size: 16px;
    font-weight: 800;
    margin-bottom: 10px;
  }

  .price-card .price {
    font-size: 36px;
    font-weight: 900;
    letter-spacing: -2px;
    line-height: 1;
    margin: 14px 0;
  }

  .price-card.premium .price { color: var(--amber); }
  .price-card.basic .price { color: var(--dark); }

  .price-card .price-sub {
    font-size: 12px;
    color: var(--warm-gray);
    margin-bottom: 18px;
  }

  .price-card.premium .price-sub { color: rgba(255,255,255,0.5); }

  .price-includes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13px;
    line-height: 1.5;
  }

  .price-includes li {
    padding-left: 18px;
    position: relative;
  }

  .price-card.basic .price-includes li::before { content: '·'; position: absolute; left: 4px; color: var(--orange); font-weight: 900; font-size: 18px; top: -3px; }
  .price-card.premium .price-includes li::before { content: '·'; position: absolute; left: 4px; color: var(--amber); font-weight: 900; font-size: 18px; top: -3px; }
  .price-card.premium .price-includes li { color: rgba(255,255,255,0.75); }

  /* ===== CTA BAND ===== */
  .cta-band {
    background: linear-gradient(135deg, var(--orange) 0%, #FF8C00 100%);
    padding: 80px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-band::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.06'%3E%3Ccircle cx='30' cy='30' r='20'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }

  .cta-band .container { position: relative; }

  .cta-band h2 {
    font-size: clamp(28px, 6vw, 50px);
    font-weight: 900;
    color: #fff;
    line-height: 1.2;
    letter-spacing: -1.5px;
    margin-bottom: 16px;
  }

  .cta-band p {
    font-size: 16px;
    color: rgba(255,255,255,0.85);
    margin-bottom: 36px;
    line-height: 1.7;
  }

  .btn-white {
    display: inline-block;
    background: #fff;
    color: var(--orange);
    font-size: 18px;
    font-weight: 900;
    padding: 18px 52px;
    border-radius: 60px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 40px rgba(0,0,0,0.2);
  }

  .btn-white:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.3);
  }

  /* ===== FAQ ===== */
  .faq-list {
    margin-top: 36px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .faq-item {
    border: 1.5px solid #E8DDD5;
    border-radius: 18px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item:hover { border-color: var(--orange); }

  .faq-q {
    padding: 20px 24px;
    font-size: 15px;
    font-weight: 700;
    color: var(--dark);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .faq-q::after {
    content: '+';
    font-size: 22px;
    color: var(--orange);
    flex-shrink: 0;
    font-weight: 300;
    transition: transform 0.2s;
  }

  .faq-item.open .faq-q::after { transform: rotate(45deg); }

  .faq-a {
    display: none;
    padding: 0 24px 20px;
    font-size: 14px;
    line-height: 1.8;
    color: var(--warm-gray);
  }

  .faq-item.open .faq-a { display: block; }

  /* ===== SPONSOR PROOF ===== */
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 28px;
  }

  .proof-chip {
    background: var(--light-orange);
    border: 1.5px solid var(--amber);
    border-radius: 14px;
    padding: 18px 14px;
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    color: var(--dark);
  }

  .proof-chip .proof-emoji { font-size: 22px; display: block; margin-bottom: 6px; }

  /* ===== REFUND ===== */
  .refund-section {
    background: #F9F4EF;
  }

  .refund-box {
    background: #fff;
    border-radius: 20px;
    padding: 28px;
    border: 1px solid #E8DDD5;
    font-size: 13px;
    line-height: 1.9;
    color: var(--warm-gray);
    margin-top: 24px;
  }

  .refund-box h4 {
    font-size: 14px;
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 10px;
  }

  .refund-box p + h4 { margin-top: 18px; }

  /* ===== CLOSING ===== */
  .closing {
    background: var(--dark);
    color: #fff;
    text-align: center;
    padding: 100px 24px;
  }

  .closing h2 {
    font-size: clamp(24px, 5vw, 42px);
    font-weight: 900;
    line-height: 1.4;
    letter-spacing: -1px;
    margin-bottom: 20px;
  }

  .closing h2 em {
    font-style: normal;
    color: var(--amber);
  }

  .closing p {
    font-size: 15px;
    color: rgba(255,255,255,0.55);
    line-height: 1.8;
    max-width: 480px;
    margin: 0 auto 40px;
  }

  /* ===== STICKY CTA ===== */
  .sticky-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--dark);
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 14px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 1000;
    backdrop-filter: blur(10px);
  }

  .sticky-cta p {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
  }

  .sticky-cta p span {
    color: var(--amber);
  }

  .sticky-cta a {
    display: inline-block;
    background: linear-gradient(135deg, var(--orange), var(--amber));
    color: #fff;
    font-size: 14px;
    font-weight: 800;
    padding: 12px 28px;
    border-radius: 40px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }


  .sticky-cta {
    gap: 14px;
  }

  .sticky-cta a {
    text-align: center;
  }

  /* ===== ANIMATIONS ===== */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== DIVIDER ===== */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--amber), transparent);
    margin: 0 24px;
    opacity: 0.4;
  }

  /* ===== RESPONSIVE ===== */

  /* 태블릿 */
  @media (max-width: 768px) {
    body { padding-bottom: 108px; }
    .benefits-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .pricing-grid { grid-template-columns: 1fr; gap: 16px; }
    .week-item { grid-template-columns: 80px 1fr; }
    .hero { min-height: auto; }
  }

  /* 모바일 */
  @media (max-width: 600px) {
    /* 전체 섹션 패딩 */
    section { padding: 50px 18px; }

    /* 히어로 */
    .hero { min-height: auto; padding: 70px 20px 50px; }
    .hero-badge { font-size: 11px; letter-spacing: 1.2px; padding: 6px 14px; margin-bottom: 22px; }
    .hero-title { letter-spacing: -0.8px; line-height: 1.2; }
    .hero-sub br { display: none; }
    .hero-voices { margin: 28px auto; gap: 8px; }
    .voice-bubble { font-size: 13px; padding: 12px 16px; }
    .btn-primary { width: 100%; max-width: 340px; font-size: 15px; padding: 15px 28px; }

    /* 섹션 제목 */
    .section-title { font-size: clamp(20px, 5.5vw, 28px); }

    /* 그리드 → 1열 */
    .benefits-grid { grid-template-columns: 1fr; gap: 10px; }
    .fit-grid { grid-template-columns: 1fr; gap: 14px; }
    .pricing-grid { grid-template-columns: 1fr; gap: 14px; }
    .proof-grid { grid-template-columns: 1fr 1fr 1fr; gap: 8px; }

    /* 베네핏 카드 */
    .benefit-card { padding: 18px 16px; }
    .benefit-card p { font-size: 18px; color:#111; line-height:1.5; }
    .benefit-icon { font-size: 24px; }

    /* 커리큘럼 */
    .week-item { grid-template-columns: 1fr; gap: 6px; padding: 16px 18px; }
    .week-label { font-size: 11px; }
    .week-content h4 { font-size: 14px; }
    .week-content p { font-size: 12px; }

    /* 일정 */
    .schedule-box { padding: 22px 18px; }
    .schedule-row { font-size: 13px; gap: 10px; }
    .schedule-icon { width: 34px; height: 34px; font-size: 15px; }

    /* 가격 */
    .price-card { padding: 24px 18px; }
    .price-card .price { font-size: 30px; }

    /* FAQ */
    .faq-q { font-size: 14px; padding: 16px 18px; }

    /* 채팅 */
    .chat-wrap { padding: 18px 14px; gap: 10px; }
    .chat-bubble { font-size: 12.5px; padding: 10px 13px; }
    .chat-col { max-width: 85%; }
    .chat-avatar { width: 30px; height: 30px; font-size: 13px; }

    /* DM 카드 */
    .dm-card { padding: 12px 14px; gap: 10px; }
    .dm-icon { width: 38px; height: 38px; font-size: 18px; border-radius: 10px; }
    .dm-from { font-size: 12px; }
    .dm-preview { font-size: 11px; }
    .dm-badge { font-size: 9px; padding: 3px 8px; }

    /* 호스트 */
    .about-host { padding: 24px 20px; }
